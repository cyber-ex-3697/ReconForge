version: "{{ reconforge_version }}"

scan:
  profile: standard
  threads: {{ threads | default(50) }}
  deep_mode: {{ deep_scan | default('false') }}
  timeout: 30
  retries: 3
  rate_limit: 10

rate:
  default: 50
  aggressive: 100
  stealth: 10

api:
  chaos_key: "{{ lookup('env', 'CHAOS_KEY') | default('') }}"
  github_token: "{{ lookup('env', 'GITHUB_TOKEN') | default('') }}"
  shodan_key: "{{ lookup('env', 'SHODAN_KEY') | default('') }}"

tools:
  subfinder_version: "2.14.0"
  nuclei_version: "3.1.0"
  httpx_version: "1.3.8"
  wordlists:
    - "/usr/share/wordlists/subdomains.txt"
  resolvers:
    - "1.1.1.1"
    - "8.8.8.8"

output:
  directory: "{{ output_dir | default('/var/lib/reconforge/output') }}"
  json: true
  html: true
  markdown: true
  screenshots: true

logging:
  level: "info"
  format: "json"
  file: true
  file_path: "{{ install_dir }}/logs/reconforge.log"
